# terraform.tfvars.example
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to terraform.tfvars and fill in the values before running
# `tofu plan` or `tofu apply`.
#
# IMPORTANT: terraform.tfvars is gitignored — never commit real values.
# ─────────────────────────────────────────────────────────────────────────────

# Linode region slug (run `linode-cli regions list` for available options)
linode_region = "us-central"

# Linode instance plan (run `linode-cli linodes types` for available options)
# g6-standard-2 = 2 vCPU / 4 GB RAM
linode_type = "g6-standard-2"

# Strong random root password (generate with: openssl rand -base64 32)
root_password = "CHANGE_ME_strong_random_password"

# Ed25519 public key for the deploy user (contents of ~/.ssh/id_ed25519.pub or similar)
deploy_ssh_public_key = "ssh-ed25519 AAAA... your-deploy-key-here"

# PostgreSQL password for the dcc database user (generate with: openssl rand -base64 32)
postgres_password = "CHANGE_ME_strong_db_password"

# DCC matcher blockchain address (per-network — check DCC docs for the correct address)
DEFAULT_MATCHER = "3PEjHv3JGjcWNpYEEkif2w8NXV4kbybKoZ7"

# Minimum trade volume threshold for rate pair acceptance in data-service
rate_pair_acceptance_volume_threshold = "0"

# Asset ID for rate calculation threshold (default: DCC)
rate_threshold_asset_id = "DCC"

# DCC node Blockchain Updates gRPC URL for blockchain-postgres-sync.
# This is the gRPC streaming endpoint on the DCC node (typically port 6881).
# Examples:
#   mainnet: grpc://mainnet-node.decentralchain.io:6881
#   stagenet: grpc://stagenet-node.decentralchain.io:6881
#   testnet:  grpc://testnet-node.decentralchain.io:6881
blockchain_updates_url = "grpc://mainnet-node.decentralchain.io:6881"

# DEX Matcher account.dat encryption password (generate with: openssl rand -base64 32)
# Required to start the matcher; protects the encrypted wallet file.
matcher_account_password = "CHANGE_ME_strong_matcher_password"

# DEX Matcher API key hash (Base58-encoded SHA256 of the API key)
# Generate: echo -n 'your-api-key' | openssl dgst -sha256 -binary | base58
matcher_api_key_hash = "CHANGE_ME_base58_sha256_of_api_key"

# ── Caddy TLS reverse proxy ───────────────────────────────────────────────────
# Public domain names for Caddy to serve via automatic Let's Encrypt TLS.
# Caddy proxies scanner → 127.0.0.1:3000 and data-service → 127.0.0.1:8080.
# DNS for both domains MUST point to this server before Caddy starts (ACME
# challenge requires the domain to resolve to the server's public IP).
# Leave empty ("") to skip Caddy config for that service.

# Block explorer / scanner frontend (Next.js SSR)
scanner_domain = "explorer.decentralchain.io"

# Data-service REST API (Hono/Node — change prefix per network)
# mainnet:  data-service.decentralchain.io
# stagenet: stagenet-data-service.decentralchain.io
# testnet:  testnet-data-service.decentralchain.io
data_service_domain = "data-service.decentralchain.io"

# Email address for Let's Encrypt expiry notifications (optional).
# If empty, certificates are requested anonymously (still works, no reminders).
acme_email = "ops@decentralchain.io"

# ── PostgreSQL off-site backup (Linode Object Storage) ────────────────────────
# rclone copies each pg_dump archive to object storage after the local dump.
# Backup bucket must already exist before the server is bootstrapped.
# All four variables must be set to enable off-site backup.
# Leave them empty ("") to use local rotation only (7-day /opt/dcc/backups/).
#
# Create a Linode Object Storage bucket: linode-cli obj mb dcc-backups-mainnet --cluster us-east-1
# Create an access key in the Linode dashboard (limited to the backup bucket only).

# Linode Object Storage (or any S3-compatible) access key
backup_obj_access_key = "CHANGE_ME_access_key"

# Linode Object Storage (or any S3-compatible) secret key
backup_obj_secret_key = "CHANGE_ME_secret_key"

# Bucket name (must already exist; create per-network for isolation)
# mainnet: dcc-backups-mainnet  stagenet: dcc-backups-stagenet  testnet: dcc-backups-testnet
backup_obj_bucket = "dcc-backups-mainnet"

# Endpoint for the Linode Object Storage region (same region as the Linode instance)
# Available regions: us-east-1, us-central, eu-central-1, ap-south-1, etc.
# Full list: https://rclone.org/s3/#linode
backup_obj_endpoint = "us-east-1.linodeobjects.com"

# ── Node wallet ──────────────────────────────────────────────────────────────
# The node-scala entrypoint reads these env vars, writes them to a temp config
# file (chmod 600), and unsets the env vars immediately — they never appear in
# /proc/<pid>/environ or `docker inspect`.
#
# To generate a wallet seed:
#   sbt "node/runMain com.decentralchain.GenesisBlockGenerator node/genesis-dcc-testnet.conf"
# The generator prints Base58-encoded seeds for each genesis wallet.
#
# IMPORTANT: the seed must be Base58-encoded (not the raw seed text).
# The raw seed text (e.g. "dcc-testnet-wallet-1") is the human-readable label
# used in genesis config; the ACTUAL seed is the Base58 encoding of that text.

# Base58-encoded seed for the node wallet (must match a genesis wallet address)
node_wallet_seed = "CHANGE_ME_base58_encoded_seed"

# Encryption password for the wallet file (generate with: openssl rand -base64 32)
node_wallet_password = "CHANGE_ME_strong_wallet_password"

