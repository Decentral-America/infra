{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "baseBranchPatterns": [
    "main"
  ],
  "extends": ["config:best-practices", ":semanticCommitTypeAll(chore)"],
  "labels": ["dependencies"],
  "osvVulnerabilityAlerts": true,
  "schedule": ["before 4am on monday"],
  "timezone": "America/Costa_Rica",
  "prConcurrentLimit": 10,
  "prHourlyLimit": 5,
  "prCreation": "not-pending",
  "platformAutomerge": true,
  "customManagers": [
    {
      "customType": "regex",
      "description": "Track the SOPS_VERSION shell variable used for curl+SHA256-verified installs — not covered by any built-in manager since it's a plain string in a run: block, not a uses:/image: field",
      "managerFilePatterns": [
        "/^\\.github/workflows/push-secrets\\.yml$/",
        "/^\\.github/workflows/update-caddy\\.yml$/"
      ],
      "matchStrings": [
        "SOPS_VERSION=\"v(?<currentValue>.*?)\""
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "getsops/sops",
      "extractVersionTemplate": "^v(?<version>.*)$"
    }
  ],
  "packageRules": [
    {
      "description": "Group Linode provider + OpenTofu version — infra-level changes reviewed together",
      "groupName": "OpenTofu + Linode provider",
      "matchPackageNames": ["opentofu", "linode/linode", "opentofu/setup-opentofu"]
    },
    {
      "description": "Pin GitHub Actions to full SHA for supply chain security — Renovate keeps them current",
      "matchManagers": ["github-actions"],
      "pinDigests": true
    },
    {
      "description": "Pin Docker and Docker Compose base images to SHA256 digests — Renovate keeps them current",
      "matchManagers": ["dockerfile", "docker-compose"],
      "pinDigests": true
    },
    {
      "automerge": true,
      "automergeType": "pr",
      "description": "Automerge GitHub Actions minor/patch SHA updates — CI gates the merge",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch", "digest"]
    },
    {
      "automerge": true,
      "automergeType": "pr",
      "description": "Automerge Docker image patch updates (low risk for infra services like Caddy)",
      "matchManagers": ["docker-compose", "dockerfile"],
      "matchUpdateTypes": ["patch", "digest"]
    },
    {
      "automerge": false,
      "dependencyDashboardApproval": true,
      "description": "Require approval for Docker image major/minor updates — may require Caddyfile or bootstrap.sh changes",
      "matchManagers": ["docker-compose", "dockerfile"],
      "matchUpdateTypes": ["major", "minor"]
    },
    {
      "automerge": true,
      "automergeType": "pr",
      "description": "Automerge Terraform/OpenTofu provider patch updates",
      "matchManagers": ["terraform"],
      "matchUpdateTypes": ["patch"]
    },
    {
      "automerge": false,
      "dependencyDashboardApproval": true,
      "description": "Require approval for Terraform/OpenTofu provider major/minor updates — may require tfvars or main.tf changes",
      "matchManagers": ["terraform"],
      "matchUpdateTypes": ["major", "minor"]
    },
    {
      "dependencyDashboardApproval": true,
      "description": "Require dashboard approval for all major updates across all managers",
      "matchUpdateTypes": ["major"]
    }
  ],
  "vulnerabilityAlerts": {
    "automerge": true,
    "description": "Security vulnerability fixes — automerge immediately after CI passes",
    "enabled": true,
    "labels": ["security", "dependencies"],
    "prCreation": "immediate"
  }
}
